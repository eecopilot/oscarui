{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ui-ir.schema.json",
  "title": "UI IR",
  "type": "object",
  "required": ["body"],
  "oneOf": [
    { "required": ["screen"], "not": { "required": ["component"] } },
    { "required": ["component"], "not": { "required": ["screen"] } }
  ],
  "additionalProperties": false,
  "properties": {
    "screen": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$",
      "description": "Screen 名，PascalCase，用于生成类型名"
    },
    "component": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$",
      "description": "Component 名，PascalCase，用于生成类型名"
    },
    "entry": { "type": "boolean" },
    "title": { "type": "string" },
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
          "type": { "$ref": "#/$defs/propType" }
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "safeArea": { "type": "boolean" },
        "contentPosition": { "enum": ["top", "center"] },
        "contentWidth": { "enum": ["compact", "normal", "wide", "fill"] }
      }
    },
    "state": {
      "type": "array",
      "items": { "$ref": "#/$defs/state" }
    },
    "body": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
          "steps": { "type": "array", "items": { "type": "string" } },
          "navigation": { "$ref": "#/$defs/navigation" }
        }
      }
    }
  },
  "$defs": {
    "spacing": { "enum": ["none", "tight", "normal", "loose"] },
    "scalarType": { "enum": ["string", "bool", "int", "double"] },
    "propType": { "enum": ["string", "bool", "int", "double", "action"] },
    "state": {
      "type": "object",
      "required": ["name", "type"],
      "oneOf": [
        { "$ref": "#/$defs/scalarState" },
        { "$ref": "#/$defs/listState" }
      ]
    },
    "scalarState": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
        "type": { "$ref": "#/$defs/scalarType" },
        "default": { "type": ["string", "boolean", "number"] }
      }
    },
    "listState": {
      "type": "object",
      "required": ["name", "type", "item"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
        "type": { "const": "list" },
        "item": {
          "type": "object",
          "required": ["fields"],
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name", "type"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
                  "type": { "$ref": "#/$defs/scalarType" }
                }
              }
            }
          }
        },
        "default": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "navigation": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "screen"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "push" },
            "screen": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "pop" }
          }
        }
      ]
    },
    "condition": {
      "type": "object",
      "required": ["state"],
      "additionalProperties": false,
      "properties": {
        "state": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
        "equals": { "type": ["string", "boolean", "number"] },
        "notEquals": { "type": ["string", "boolean", "number"] }
      },
      "not": { "required": ["equals", "notEquals"] }
    },
    "textBinding": {
      "type": "string",
      "pattern": "^(item\\.)?[a-z][A-Za-z0-9]*$"
    },
    "node": {
      "type": "object",
      "required": ["type"],
      "discriminator": { "propertyName": "type" },
      "oneOf": [
        { "$ref": "#/$defs/column" },
        { "$ref": "#/$defs/row" },
        { "$ref": "#/$defs/text" },
        { "$ref": "#/$defs/image" },
        { "$ref": "#/$defs/button" },
        { "$ref": "#/$defs/textField" },
        { "$ref": "#/$defs/list" },
        { "$ref": "#/$defs/componentNode" },
        { "$ref": "#/$defs/spacer" }
      ]
    },
    "column": {
      "type": "object",
      "required": ["type", "children"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "column" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "spacing": { "$ref": "#/$defs/spacing" },
        "padding": { "$ref": "#/$defs/spacing" },
        "align": { "enum": ["start", "center", "end"] },
        "children": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } }
      }
    },
    "row": {
      "type": "object",
      "required": ["type", "children"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "row" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "spacing": { "$ref": "#/$defs/spacing" },
        "padding": { "$ref": "#/$defs/spacing" },
        "align": { "enum": ["start", "center", "end"] },
        "children": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } }
      }
    },
    "text": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "text" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "value": { "type": "string" },
        "bind": { "$ref": "#/$defs/textBinding" },
        "role": { "enum": ["title", "heading", "body", "caption"] },
        "color": { "enum": ["textPrimary", "textSecondary", "primary"] }
      },
      "oneOf": [
        { "required": ["value"], "not": { "required": ["bind"] } },
        { "required": ["bind"], "not": { "required": ["value"] } }
      ]
    },
    "image": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "image" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "url": { "type": "string" },
        "height": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "radius": { "enum": ["none", "small", "normal", "large"] }
      }
    },
    "button": {
      "type": "object",
      "required": ["type", "label", "action"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "button" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "label": { "type": "string" },
        "role": { "enum": ["primary", "secondary", "ghost"] },
        "action": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" }
      }
    },
    "textField": {
      "type": "object",
      "required": ["type", "bind"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "textField" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "bind": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
        "placeholder": { "type": "string" },
        "secure": { "type": "boolean" },
        "keyboard": { "enum": ["default", "email", "number", "phone"] }
      }
    },
    "list": {
      "type": "object",
      "required": ["type", "bind", "itemTemplate"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "list" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "bind": { "type": "string" },
        "itemTemplate": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/node" } }
      }
    },
    "spacer": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "spacer" },
        "visibleWhen": { "$ref": "#/$defs/condition" }
      }
    },
    "propValue": {
      "type": "string",
      "pattern": "^(item\\.)?[a-z][A-Za-z0-9]*$"
    },
    "componentNode": {
      "type": "object",
      "required": ["type", "name"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "component" },
        "visibleWhen": { "$ref": "#/$defs/condition" },
        "name": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" },
        "props": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "$ref": "#/$defs/propValue" },
              { "type": "string" },
              { "type": "boolean" },
              { "type": "number" }
            ]
          }
        }
      }
    }
  }
}
