{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plugin.schema.json",
  "title": "OscarUI Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["importer", "validator", "compiler", "snapshot"]
      },
      "uniqueItems": true
    },
    "entry": {
      "type": "string"
    },
    "configSchema": {
      "type": "object"
    }
  }
}
