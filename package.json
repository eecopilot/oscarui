{
  "name": "oscarui",
  "version": "1.0.0",
  "description": "OscarUI: Open Source Cross Apple/Android Renderer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eecopilot/oscarui.git"
  },
  "homepage": "https://github.com/eecopilot/oscarui#readme",
  "bugs": {
    "url": "https://github.com/eecopilot/oscarui/issues"
  },
  "bin": {
    "oscarui": "bin/oscarui.mjs"
  },
  "files": [
    "bin/",
    "compiler/",
    "schema/",
    "runtime/",
    "templates/",
    "docs/",
    "CHANGELOG.md",
    "README.md",
    "README.zh-CN.md",
    "ROADMAP.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "node compiler/aic.mjs validate",
    "build": "node compiler/aic.mjs build",
    "runtime:validate": "node compiler/aic.mjs runtime:validate",
    "build:runtime": "node compiler/aic.mjs build:runtime",
    "runtime:parity": "node compiler/aic.mjs runtime:parity",
    "runtime:selftest": "node compiler/runtime/selftest.mjs",
    "runtime:install:ios": "node compiler/aic.mjs runtime:install:ios",
    "runtime:install:android": "node compiler/aic.mjs runtime:install:android",
    "author:loop": "node compiler/aic.mjs author:loop",
    "figma:import": "node compiler/aic.mjs figma:import",
    "plugins:validate": "node compiler/aic.mjs plugins:validate",
    "doctor:ios": "node compiler/aic.mjs doctor:ios",
    "dry-run:ios": "node compiler/aic.mjs dry-run:ios",
    "dev:ios": "node compiler/aic.mjs dev:ios",
    "dry-run:ios:runtime": "node compiler/aic.mjs dry-run:ios:runtime",
    "dev:ios:runtime": "node compiler/aic.mjs dev:ios:runtime",
    "doctor:android": "node compiler/aic.mjs doctor:android",
    "dry-run:android": "node compiler/aic.mjs dry-run:android",
    "dev:android": "node compiler/aic.mjs dev:android",
    "dry-run:android:runtime": "node compiler/aic.mjs dry-run:android:runtime",
    "dev:android:runtime": "node compiler/aic.mjs dev:android:runtime",
    "snapshots": "node compiler/aic.mjs snapshots",
    "snapshots:runtime": "node compiler/aic.mjs snapshots:runtime",
    "snapshots:diff": "node compiler/aic.mjs snapshots:diff",
    "snapshots:runtime-parity": "node compiler/aic.mjs snapshots:runtime-parity",
    "snapshots:accept": "node compiler/aic.mjs snapshots:accept",
    "visual:review": "node compiler/aic.mjs visual:review",
    "author:visual-review": "npm run snapshots && npm run visual:review",
    "verify:ui": "node compiler/aic.mjs snapshots",
    "cli": "node bin/oscarui.mjs",
    "pack:check": "node compiler/package-selftest.mjs",
    "publish:dry-run": "npm publish --dry-run --ignore-scripts",
    "doctor:ci": "node compiler/doctor-ci.mjs",
    "release:check": "node compiler/release-check.mjs",
    "golden:update": "node compiler/golden-test.mjs --update",
    "golden:verify": "node compiler/golden-test.mjs",
    "host:verify": "node compiler/host-reproducibility.mjs",
    "diagnostics:test": "node compiler/diagnostics-selftest.mjs",
    "test": "npm run validate && npm run plugins:validate && npm run build && npm run build:runtime && npm run runtime:selftest && npm run runtime:parity && npm run golden:verify && npm run host:verify && npm run diagnostics:test"
  },
  "keywords": [
    "swiftui",
    "jetpack-compose",
    "ios",
    "android",
    "ui-compiler",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.9.0"
  }
}
